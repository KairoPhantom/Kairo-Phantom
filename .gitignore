# ── Rust ──────────────────────────────────────────────────────
/target
**/*.rs.bk
**/*.pdb
# Cargo.lock is kept for binary crates (intentional)

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDE & Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.vs/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/

# ── Build artifacts ───────────────────────────────────────────
dist/
build/
*.dmg
*.msi
*.AppImage
*.deb
*.rpm

# ── Build artifacts that should NOT be in git ────────────────────────────────
target_check_tmp/
playground/target/
graphify-out/graph.json
mutants.out/
mutants.out.old/
mutants_real.out/

# ── Runtime data (not source) ─────────────────────────────────
.kairo/
.kairo-phantom/
graphify-out/cache/
*.log
kairo_err.log

# ── Sensitive / secrets ───────────────────────────────────────
.env
**/.env
*.key
*.pem
credentials.*
secrets.*
*.secret

# ── Private planning docs (never publish) ─────────────────────
.launch/
.planning/
.gsd/
session_report_*.md
clippy_*.txt
gauntlet_*.txt
stress_results.json
