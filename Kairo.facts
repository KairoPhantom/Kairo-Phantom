# Kairo Phantom — Facts Registry (48 Facts)
# Format: @implemented or @spec
# @implemented: feature is coded and test passes
# @spec: planned — test command is the gate before shipping

# ── CORE ENGINE ──────────────────────────────────────────────────────────────

@implemented: basic ghost-write in Word replaces selected text
  command: cargo test --test e2e_win_t1 -- --nocapture

@implemented: streaming cancel (Esc) preserves original text
  command: cargo test --test e2e_win_t2 -- --nocapture

@implemented: Tab confirms AI suggestion before injection
  command: cargo test --test e2e_win_t3 -- --nocapture

@implemented: Alt+M hotkey activates ghost mode
  command: cargo test --test e2e_win_t4 -- --nocapture

# ── SECURITY ────────────────────────────────────────────────────────────────

@implemented: no system-prompt leakage in any output
  command: cargo test --test sentinel_leakage -- --nocapture

@implemented: prompt injection blocked (ignore previous instructions)
  command: cargo test --lib guardrails::tests::test_injection_blocked -- --nocapture

@implemented: PII redacted from all outputs (email, phone, SSN)
  command: cargo test --lib pii_guard::tests -- --nocapture

@implemented: sentinel hash never appears in any LLM response
  command: cargo test --lib quality_gate::tests::test_sentinel_hash -- --nocapture

@implemented: DAN/developer-mode jailbreak attempts blocked
  command: cargo test --lib guardrails::tests::test_jailbreak -- --nocapture

